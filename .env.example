# Runtime environment variables required by this project.
# Copy to .env and fill in real values. Never commit .env.
# This file is safe to commit; it contains no secrets.

# anthropic SDK key — Claude Code OAuth does NOT propagate here; set explicitly.
ANTHROPIC_API_KEY=your_key_here
# openai SDK key — Claude Code OAuth does NOT propagate here; set explicitly.
OPENAI_API_KEY=your_key_here